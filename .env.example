# Backend origin (bare, no trailing /api). axios appends /api automatically.
# Local dev: leave EMPTY to use the Vite dev proxy (proxies /api to http://localhost:5000)
#            OR set to http://localhost:5000 to hit the backend directly
# Production (Vercel): set this in Vercel Project Settings → Environment Variables
#                      Example: https://citywala-backend-production.up.railway.app
VITE_API_URL=
