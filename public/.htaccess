<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files/directories (js, css, images, etc.) as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else (e.g. /admin/login, /admin/dashboard) falls back to index.html
  # so React Router can handle the route client-side
  RewriteRule ^ /index.html [L]
</IfModule>
